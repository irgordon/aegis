{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/ApprovalRequest.schema.json",
  "title": "ApprovalRequest",
  "type": "object",
  "required": [
    "schema_version",
    "approval_id",
    "execution_id",
    "action_id",
    "request_hash",
    "status",
    "approval_scope",
    "policy_provenance",
    "created_at",
    "expires_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "approval_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "request_hash": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "denied",
        "expired",
        "canceled"
      ]
    },
    "approval_scope": {
      "type": "object",
      "required": [
        "tool_name",
        "capability_class",
        "environment"
      ],
      "properties": {
        "tool_name": {
          "type": "string",
          "minLength": 1
        },
        "capability_class": {
          "type": "string",
          "enum": [
            "L2",
            "L3"
          ]
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "safe_summary": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "approver_identity": {
      "type": [
        "string",
        "null"
      ]
    },
    "decision_reason": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy_provenance": {
      "type": "object",
      "required": [
        "bundle_id",
        "version",
        "policy_hash",
        "environment"
      ],
      "properties": {
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "policy_hash": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "signer_identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "activated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "decided_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
