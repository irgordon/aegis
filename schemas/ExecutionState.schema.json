{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/ExecutionState.schema.json",
  "title": "ExecutionState",
  "type": "object",
  "required": [
    "schema_version",
    "execution_id",
    "run_id",
    "action_id",
    "state",
    "policy_provenance",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "enum": [
        "created",
        "validating",
        "policy_evaluated",
        "pending_approval",
        "approved",
        "denied",
        "executing",
        "executed",
        "failed",
        "canceled",
        "replayed"
      ]
    },
    "attempt_number": {
      "type": "integer",
      "minimum": 0
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "replay_token": {
      "type": [
        "string",
        "null"
      ]
    },
    "request_hash": {
      "type": "string",
      "minLength": 1
    },
    "approval_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "policy_provenance": {
      "type": "object",
      "required": [
        "bundle_id",
        "version",
        "policy_hash",
        "environment"
      ],
      "properties": {
        "bundle_id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "policy_hash": {
          "type": "string",
          "minLength": 1
        },
        "environment": {
          "type": "string",
          "minLength": 1
        },
        "signer_identity": {
          "type": [
            "string",
            "null"
          ]
        },
        "activated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "terminal_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
