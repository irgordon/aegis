{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/PolicyBundleManifest.schema.json",
  "title": "PolicyBundleManifest",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_id",
    "version",
    "policy_hash",
    "environment",
    "created_at",
    "compatibility",
    "contents"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "policy_hash": {
      "type": "string",
      "minLength": 1
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "signer_identity": {
      "type": [
        "string",
        "null"
      ]
    },
    "signature": {
      "type": [
        "string",
        "null"
      ]
    },
    "compatibility": {
      "type": "object",
      "required": [
        "gateway",
        "schemas",
        "wrappers",
        "api"
      ],
      "properties": {
        "gateway": {
          "type": "string",
          "minLength": 1
        },
        "schemas": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "wrappers": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "api": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "contents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "path",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "sha256": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
