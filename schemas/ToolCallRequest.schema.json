{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegis.local/schemas/ToolCallRequest.schema.json",
  "title": "ToolCallRequest",
  "type": "object",
  "required": [
    "schema_version",
    "request_id",
    "run_id",
    "task_id",
    "action_id",
    "actor",
    "tool",
    "params",
    "environment",
    "requested_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "execution_id": {
      "type": "string",
      "minLength": 1
    },
    "idempotency_key": {
      "type": "string",
      "minLength": 1
    },
    "attempt_number": {
      "type": "integer",
      "minimum": 0
    },
    "replay_token": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "actor_id",
        "actor_type"
      ],
      "properties": {
        "actor_id": {
          "type": "string",
          "minLength": 1
        },
        "actor_type": {
          "type": "string",
          "enum": [
            "agent",
            "orchestrator",
            "user",
            "service"
          ]
        },
        "display_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "tool": {
      "type": "object",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "capability_class": {
          "type": "string",
          "enum": [
            "L0",
            "L1",
            "L2",
            "L3"
          ]
        }
      },
      "additionalProperties": false
    },
    "params": {
      "type": "object",
      "additionalProperties": true
    },
    "environment": {
      "type": "string",
      "minLength": 1
    },
    "requested_at": {
      "type": "string",
      "format": "date-time"
    },
    "orchestrator": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "run_reference": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
