component NavLabel inherits Rectangle {
    in property <string> label_text;
    in property <bool> selected;

    height: 38px;
    border-radius: 6px;
    background: selected ? #294d7c : #102033;

    Text {
        text: root.label_text;
        color: selected ? #ffffff : #b8c7dc;
        font-size: 15px;
        font-weight: selected ? 700 : 500;
        vertical-alignment: center;
        horizontal-alignment: left;
        x: 14px;
    }
}

component StatusCard inherits Rectangle {
    in property <string> card_title;
    in property <string> card_status;
    in property <string> summary;
    in property <string> evidence_source;
    in property <color> accent;

    width: 142px;
    height: 114px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #d6deea;
    background: #ffffff;

    VerticalLayout {
        padding-top: 12px;
        padding-right: 12px;
        padding-bottom: 12px;
        padding-left: 12px;
        spacing: 4px;

        Text {
            text: root.card_title;
            color: #1f2937;
            font-size: 12px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Text {
            text: root.card_status;
            color: root.accent;
            font-size: 17px;
            font-weight: 800;
            wrap: word-wrap;
        }

        Text {
            text: root.summary;
            color: #4b5c75;
            font-size: 11px;
            wrap: word-wrap;
        }

        Text {
            text: "source: " + root.evidence_source;
            color: #6b7c93;
            font-size: 10px;
            wrap: word-wrap;
        }
    }
}

component TimelineStep inherits Rectangle {
    in property <string> stage_label;
    in property <string> stage_status;
    in property <string> summary;
    in property <color> accent;

    width: 96px;
    height: 86px;
    background: #ffffff;

    VerticalLayout {
        spacing: 4px;
        alignment: start;

        Rectangle {
            width: 24px;
            height: 24px;
            border-radius: 12px;
            background: root.accent;
        }

        Text {
            text: root.stage_label;
            color: #111827;
            font-size: 11px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Text {
            text: root.stage_status;
            color: root.accent;
            font-size: 11px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Text {
            text: root.summary;
            color: #52637a;
            font-size: 9px;
            wrap: word-wrap;
        }
    }
}

component ErrorDetail inherits HorizontalLayout {
    in property <string> detail_label;
    in property <string> detail_value;

    spacing: 8px;

    Text {
        width: 82px;
        text: root.detail_label;
        color: #6b1d1d;
        font-size: 11px;
        font-weight: 700;
    }

    Text {
        text: root.detail_value;
        color: #2b2f38;
        font-size: 12px;
        wrap: word-wrap;
    }
}

component ErrorCard inherits Rectangle {
    in property <string> error_title;
    in property <string> error_source;
    in property <string> error_code;
    in property <string> error_severity;
    in property <string> error_message;
    in property <string> error_reason;
    in property <string> error_next_action;
    in property <string> error_location;

    width: 292px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #ef9a9a;
    background: #fff8f8;

    VerticalLayout {
        padding: 18px;
        spacing: 12px;

        Text {
            text: root.error_title;
            color: #8f1d1d;
            font-size: 16px;
            font-weight: 800;
        }

        Text {
            text: root.error_source;
            color: #7f3b3b;
            font-size: 11px;
        }

        ErrorDetail {
            detail_label: "Code";
            detail_value: root.error_code;
        }

        ErrorDetail {
            detail_label: "Severity";
            detail_value: root.error_severity;
        }

        ErrorDetail {
            detail_label: "Message";
            detail_value: root.error_message;
        }

        ErrorDetail {
            detail_label: "Reason";
            detail_value: root.error_reason;
        }

        ErrorDetail {
            detail_label: "Next";
            detail_value: root.error_next_action;
        }

        ErrorDetail {
            detail_label: "Location";
            detail_value: root.error_location;
        }
    }
}

component RecoveryDetail inherits HorizontalLayout {
    in property <string> detail_label;
    in property <string> detail_value;

    spacing: 8px;

    Text {
        width: 108px;
        text: root.detail_label;
        color: #3b3667;
        font-size: 11px;
        font-weight: 700;
    }

    Text {
        text: root.detail_value;
        color: #2b2f38;
        font-size: 12px;
        wrap: word-wrap;
    }
}

component RecoveryInspectionCard inherits Rectangle {
    width: 292px;
    height: 188px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #c4b5fd;
    background: #fbfaff;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: "Sample Recovery Inspection";
            color: #4c1d95;
            font-size: 15px;
            font-weight: 800;
        }

        RecoveryDetail {
            detail_label: "Status";
            detail_value: "Inspection available";
        }

        RecoveryDetail {
            detail_label: "Execution";
            detail_value: "sample_exec_001";
        }

        RecoveryDetail {
            detail_label: "Last state";
            detail_value: "Completed";
        }

        RecoveryDetail {
            detail_label: "Terminal";
            detail_value: "Yes";
        }

        RecoveryDetail {
            detail_label: "Recoverability";
            detail_value: "Not recoverable";
        }

        Text {
            text: "No inspection errors in sample evidence. This card does not read state logs.";
            color: #4b5563;
            font-size: 11px;
            wrap: word-wrap;
        }
    }
}

component RecoveryPlanCard inherits Rectangle {
    width: 292px;
    height: 214px;
    border-radius: 8px;
    border-width: 1px;
    border-color: #fdba74;
    background: #fffaf3;

    VerticalLayout {
        padding: 14px;
        spacing: 8px;

        Text {
            text: "Sample Recovery Plan";
            color: #9a3412;
            font-size: 15px;
            font-weight: 800;
        }

        RecoveryDetail {
            detail_label: "Plan status";
            detail_value: "Planned";
        }

        RecoveryDetail {
            detail_label: "Outcome";
            detail_value: "Not recoverable";
        }

        RecoveryDetail {
            detail_label: "Future action";
            detail_value: "No future action";
        }

        RecoveryDetail {
            detail_label: "Reason";
            detail_value: "Execution already reached a terminal completed state.";
        }

        Text {
            text: "Safe labels: Future evaluation only; Audit retry candidate; Audit retry only; Not recoverable: evidence corrupted; Manual review only.";
            color: #4b5563;
            font-size: 11px;
            wrap: word-wrap;
        }

        Text {
            text: "Sample guidance only. This UI does not inspect live state, approve recovery, execute audit retry, replay, or resume execution.";
            color: #7c2d12;
            font-size: 11px;
            wrap: word-wrap;
        }
    }
}

export component AegisWindow inherits Window {
    in-out property <string> evidence_mode_label: "Sample evidence fallback";
    in-out property <string> header_summary: "Fixture-backed operator evidence rendering";
    in-out property <string> policy_bundle_status: "Verified";
    in-out property <string> policy_bundle_summary: "Bundle integrity evidence is present.";
    in-out property <string> policy_decision_status: "Allowed";
    in-out property <string> policy_decision_summary: "Request matches a local policy rule.";
    in-out property <string> authorization_status: "Authorized";
    in-out property <string> authorization_summary: "Wrapper execution authority is bound.";
    in-out property <string> credential_boundary_status: "Satisfied";
    in-out property <string> credential_boundary_summary: "Required class matches authorization.";
    in-out property <string> credential_injection_status: "Handle issued";
    in-out property <string> credential_injection_summary: "Safe local handle reference is present.";
    in-out property <string> wrapper_execution_status: "Executed";
    in-out property <string> wrapper_execution_summary: "Bounded wrapper result is recorded.";
    in-out property <string> audit_status: "Recorded";
    in-out property <string> audit_summary: "Audit evidence is available.";
    in-out property <string> state_status: "Completed";
    in-out property <string> state_summary: "Lifecycle evidence reached completed.";
    in-out property <string> request_status: "Received";
    in-out property <string> request_summary: "Sample request accepted.";
    in-out property <string> validation_status: "Valid";
    in-out property <string> validation_summary: "Request shape matches.";
    in-out property <string> bundle_timeline_status: "Verified";
    in-out property <string> bundle_timeline_summary: "Bundle evidence present.";
    in-out property <string> policy_timeline_status: "Allowed";
    in-out property <string> policy_timeline_summary: "Allow rule matched.";
    in-out property <string> authorization_timeline_status: "Authorized";
    in-out property <string> authorization_timeline_summary: "Wrapper authority bound.";
    in-out property <string> credential_boundary_timeline_status: "Satisfied";
    in-out property <string> credential_boundary_timeline_summary: "Class check passed.";
    in-out property <string> credential_injection_timeline_status: "Handle issued";
    in-out property <string> credential_injection_timeline_summary: "Safe local handle ref.";
    in-out property <string> dispatch_status: "Dispatched";
    in-out property <string> dispatch_summary: "Registered wrapper selected.";
    in-out property <string> wrapper_timeline_status: "Executed";
    in-out property <string> wrapper_timeline_summary: "Bounded result present.";
    in-out property <string> audit_timeline_status: "Recorded";
    in-out property <string> audit_timeline_summary: "Audit evidence exists.";
    in-out property <string> state_timeline_status: "Completed";
    in-out property <string> state_timeline_summary: "Terminal sample state.";
    in-out property <string> error_title: "Sample Normalized Error";
    in-out property <string> error_source: "Static structured_error_report evidence";
    in-out property <string> error_code: "policy_denied";
    in-out property <string> error_severity: "HIGH";
    in-out property <string> error_message: "Request was denied by policy.";
    in-out property <string> error_reason: "The requested action did not match an allowed policy rule.";
    in-out property <string> error_next_action: "Review the policy decision and request context.";
    in-out property <string> error_location: "policy_evaluation";

    title: "AEGIS";
    width: 1280px;
    height: 820px;
    background: #f5f7fb;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 220px;
            background: #102033;

            VerticalLayout {
                padding-top: 30px;
                padding-right: 22px;
                padding-bottom: 24px;
                padding-left: 22px;
                spacing: 14px;

                Text {
                    text: "AEGIS";
                    color: #ffffff;
                    font-size: 32px;
                    font-weight: 800;
                    horizontal-alignment: center;
                }

                Text {
                    text: "AI Execution Governance & Interception System";
                    color: #d9e6f7;
                    font-size: 13px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 1px;
                    background: #2d415c;
                }

                NavLabel { label_text: "Overview"; selected: true; }
                NavLabel { label_text: "Executions"; selected: false; }
                NavLabel { label_text: "Audit"; selected: false; }
                NavLabel { label_text: "State"; selected: false; }
                NavLabel { label_text: "Recovery"; selected: false; }
                NavLabel { label_text: "Policy"; selected: false; }
                NavLabel { label_text: "Settings"; selected: false; }

                Rectangle {
                    vertical-stretch: 1;
                    background: #102033;
                }

                Text {
                    text: root.evidence_mode_label;
                    color: #91a6c2;
                    font-size: 12px;
                    horizontal-alignment: center;
                }
            }
        }

        Rectangle {
            background: #f5f7fb;

            VerticalLayout {
                padding-top: 28px;
                padding-right: 28px;
                padding-bottom: 24px;
                padding-left: 28px;
                spacing: 14px;

                HorizontalLayout {
                    spacing: 14px;
                    alignment: start;

                    Text {
                        text: "AEGIS";
                        color: #111827;
                        font-size: 40px;
                        font-weight: 800;
                    }

                    Rectangle {
                        width: 104px;
                        height: 28px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: #8fb4ee;
                        background: #eaf2ff;

                        Text {
                            text: "PRE-ALPHA";
                            color: #2358a6;
                            font-size: 12px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        text: root.header_summary;
                        color: #40506a;
                        font-size: 17px;
                        vertical-alignment: center;
                    }
                }

                HorizontalLayout {
                    spacing: 16px;

                    VerticalLayout {
                        spacing: 12px;

                        Text {
                            text: "Status Cards";
                            color: #1f2937;
                            font-size: 17px;
                            font-weight: 800;
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            StatusCard { card_title: "Policy Bundle"; card_status: root.policy_bundle_status; summary: root.policy_bundle_summary; evidence_source: "policy_bundle"; accent: #157a33; }
                            StatusCard { card_title: "Policy Decision"; card_status: root.policy_decision_status; summary: root.policy_decision_summary; evidence_source: "policy_evaluation"; accent: #157a33; }
                            StatusCard { card_title: "Authorization"; card_status: root.authorization_status; summary: root.authorization_summary; evidence_source: "execution_authorization"; accent: #157a33; }
                            StatusCard { card_title: "Credential Boundary"; card_status: root.credential_boundary_status; summary: root.credential_boundary_summary; evidence_source: "credential_boundary"; accent: #157a33; }
                            StatusCard { card_title: "Credential Injection"; card_status: root.credential_injection_status; summary: root.credential_injection_summary; evidence_source: "credential_injection"; accent: #2f65c7; }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            StatusCard { card_title: "Wrapper Execution"; card_status: root.wrapper_execution_status; summary: root.wrapper_execution_summary; evidence_source: "wrapper_execution"; accent: #157a33; }
                            StatusCard { card_title: "Audit Log"; card_status: root.audit_status; summary: root.audit_summary; evidence_source: "audit_record"; accent: #157a33; }
                            StatusCard { card_title: "State Log"; card_status: root.state_status; summary: root.state_summary; evidence_source: "execution_lifecycle"; accent: #2f65c7; }
                            StatusCard { card_title: "Recovery Inspection"; card_status: "Sample only"; summary: "Live health.check does not inspect state logs."; evidence_source: "sample recovery_inspection_report"; accent: #6b46c1; }
                            StatusCard { card_title: "Recovery Plan"; card_status: "Sample only"; summary: "Live health.check does not plan recovery."; evidence_source: "sample recovery_plan_report"; accent: #c46210; }
                        }

                        Rectangle {
                            height: 238px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: #d6deea;
                            background: #ffffff;

                            VerticalLayout {
                                padding: 16px;
                                spacing: 10px;

                                Text {
                                    text: "Execution Timeline";
                                    color: #1f2937;
                                    font-size: 17px;
                                    font-weight: 800;
                                }

                                Text {
                                    text: "Display labels derive from live health.check backend evidence when available; recovery stages remain sample-only.";
                                    color: #52637a;
                                    font-size: 12px;
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    TimelineStep { stage_label: "Request"; stage_status: root.request_status; summary: root.request_summary; accent: #2f65c7; }
                                    TimelineStep { stage_label: "Validation"; stage_status: root.validation_status; summary: root.validation_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "Policy Bundle"; stage_status: root.bundle_timeline_status; summary: root.bundle_timeline_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "Policy Decision"; stage_status: root.policy_timeline_status; summary: root.policy_timeline_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "Authorization"; stage_status: root.authorization_timeline_status; summary: root.authorization_timeline_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "Credential Boundary"; stage_status: root.credential_boundary_timeline_status; summary: root.credential_boundary_timeline_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "Credential Injection"; stage_status: root.credential_injection_timeline_status; summary: root.credential_injection_timeline_summary; accent: #2f65c7; }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    TimelineStep { stage_label: "Wrapper Dispatch"; stage_status: root.dispatch_status; summary: root.dispatch_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "Wrapper Execution"; stage_status: root.wrapper_timeline_status; summary: root.wrapper_timeline_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "Audit"; stage_status: root.audit_timeline_status; summary: root.audit_timeline_summary; accent: #157a33; }
                                    TimelineStep { stage_label: "State"; stage_status: root.state_timeline_status; summary: root.state_timeline_summary; accent: #2f65c7; }
                                    TimelineStep { stage_label: "Recovery Inspection"; stage_status: "Sample only"; summary: "No live state inspection."; accent: #6b46c1; }
                                    TimelineStep { stage_label: "Recovery Plan"; stage_status: "Sample only"; summary: "No live recovery plan."; accent: #c46210; }
                                }
                            }
                        }

                        Rectangle {
                            height: 84px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: #b7cae9;
                            background: #edf5ff;

                            HorizontalLayout {
                                padding: 16px;
                                spacing: 14px;

                                Text {
                                    width: 124px;
                                    text: "Backend evidence drives this UI";
                                    color: #133e75;
                                    font-size: 14px;
                                    font-weight: 800;
                                    wrap: word-wrap;
                                }

                                Text {
                                    text: "The UI is an operator surface, not an authority boundary. This view renders fixed read-only live health.check evidence when available and labeled sample recovery evidence otherwise; it does not accept arbitrary requests, evaluate policy, authorize execution, issue credentials, dispatch mutation wrappers, write audit or state logs, inspect state logs, plan recovery, replay, or recover.";
                                    color: #2e4b70;
                                    font-size: 13px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 12px;

                        ErrorCard {
                            error_title: root.error_title;
                            error_source: root.error_source;
                            error_code: root.error_code;
                            error_severity: root.error_severity;
                            error_message: root.error_message;
                            error_reason: root.error_reason;
                            error_next_action: root.error_next_action;
                            error_location: root.error_location;
                        }
                        RecoveryInspectionCard {}
                        RecoveryPlanCard {}
                    }
                }
            }
        }
    }
}
