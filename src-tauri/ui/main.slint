export global AegisPalette {
    out property <color> primary_dark: #0D3B66;
    out property <color> surface: #FAF0CA;
    out property <color> attention: #F4D35E;
    out property <color> secondary_accent: #EE964B;
    out property <color> critical: #F95738;
    out property <color> panel: #fff8dc;
    out property <color> card: #fffdf4;
    out property <color> border: #d8c98e;
    out property <color> muted_text: #4b6074;
}

export global AegisTypography {
    out property <string> serif_first: "Georgia";
}

component EvidenceBadge inherits Rectangle {
    in property <string> badge_text;
    in property <color> tone;
    in property <color> text_tone: AegisPalette.primary_dark;
    in property <length> badge_width: 154px;

    width: badge_width;
    height: 28px;
    border-radius: 14px;
    border-width: 1px;
    border-color: tone;
    background: tone;

    Text {
        text: root.badge_text;
        color: root.text_tone;
        font-family: AegisTypography.serif_first;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component SectionTitle inherits Text {
    in property <string> title_text;

    text: root.title_text;
    color: AegisPalette.primary_dark;
    font-family: AegisTypography.serif_first;
    font-size: 17px;
    font-weight: 800;
}

component NavLabel inherits Rectangle {
    in property <string> label_text;
    in property <bool> selected;

    height: 38px;
    border-radius: 6px;
    background: selected ? AegisPalette.secondary_accent : AegisPalette.primary_dark;

    Text {
        text: root.label_text;
        color: selected ? AegisPalette.primary_dark : AegisPalette.surface;
        font-family: AegisTypography.serif_first;
        font-size: 15px;
        font-weight: selected ? 700 : 500;
        vertical-alignment: center;
        horizontal-alignment: left;
        x: 14px;
    }
}

component StatusCard inherits Rectangle {
    in property <string> card_title;
    in property <string> card_status;
    in property <string> summary;
    in property <string> evidence_source;
    in property <color> accent;

    width: 128px;
    height: 86px;
    border-radius: 8px;
    border-width: 1px;
    border-color: AegisPalette.border;
    background: AegisPalette.card;

    VerticalLayout {
        padding-top: 12px;
        padding-right: 12px;
        padding-bottom: 12px;
        padding-left: 12px;
        spacing: 8px;

        Text {
            text: root.card_title;
            color: AegisPalette.primary_dark;
            font-family: AegisTypography.serif_first;
            font-size: 12px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Text {
            text: root.card_status;
            color: root.accent;
            font-family: AegisTypography.serif_first;
            font-size: 17px;
            font-weight: 800;
            wrap: word-wrap;
        }
    }
}

component TimelineStep inherits Rectangle {
    in property <string> stage_label;
    in property <string> stage_status;
    in property <string> summary;
    in property <color> accent;

    width: 88px;
    height: 66px;
    background: AegisPalette.card;

    VerticalLayout {
        spacing: 3px;
        alignment: start;

        Rectangle {
            width: 24px;
            height: 24px;
            border-radius: 12px;
            background: root.accent;
        }

        Text {
            text: root.stage_label;
            color: AegisPalette.primary_dark;
            font-family: AegisTypography.serif_first;
            font-size: 10px;
            font-weight: 700;
            wrap: word-wrap;
        }

        Text {
            text: root.stage_status;
            color: root.accent;
            font-family: AegisTypography.serif_first;
            font-size: 10px;
            font-weight: 700;
            wrap: word-wrap;
        }
    }
}

component ErrorDetail inherits HorizontalLayout {
    in property <string> detail_label;
    in property <string> detail_value;

    spacing: 8px;

    Text {
        width: 82px;
        text: root.detail_label;
        color: AegisPalette.critical;
        font-family: AegisTypography.serif_first;
        font-size: 10px;
        font-weight: 700;
    }

    Text {
        text: root.detail_value;
        color: AegisPalette.primary_dark;
        font-family: AegisTypography.serif_first;
        font-size: 11px;
        wrap: word-wrap;
    }
}

component ErrorCard inherits Rectangle {
    in property <string> error_title;
    in property <string> error_source;
    in property <string> error_code;
    in property <string> error_severity;
    in property <string> error_message;
    in property <string> error_reason;
    in property <string> error_next_action;
    in property <string> error_location;

    width: 292px;
    height: 198px;
    border-radius: 8px;
    border-width: 1px;
    border-color: AegisPalette.critical;
    background: AegisPalette.card;

    VerticalLayout {
        padding: 14px;
        spacing: 7px;

        Text {
            text: root.error_title;
            color: AegisPalette.critical;
            font-family: AegisTypography.serif_first;
            font-size: 15px;
            font-weight: 800;
        }

        Text {
            text: root.error_source;
            color: AegisPalette.primary_dark;
            font-family: AegisTypography.serif_first;
            font-size: 11px;
            wrap: word-wrap;
        }

        ErrorDetail {
            detail_label: "Code";
            detail_value: root.error_code;
        }

        ErrorDetail {
            detail_label: "Severity";
            detail_value: root.error_severity;
        }

        ErrorDetail {
            detail_label: "Message";
            detail_value: root.error_message;
        }

        ErrorDetail {
            detail_label: "Reason";
            detail_value: root.error_reason;
        }

        ErrorDetail {
            detail_label: "Next";
            detail_value: root.error_next_action;
        }

        ErrorDetail {
            detail_label: "Location";
            detail_value: root.error_location;
        }
    }
}

component RecoveryDetail inherits HorizontalLayout {
    in property <string> detail_label;
    in property <string> detail_value;

    spacing: 8px;

    Text {
        width: 108px;
        text: root.detail_label;
        color: AegisPalette.primary_dark;
        font-family: AegisTypography.serif_first;
        font-size: 11px;
        font-weight: 700;
    }

    Text {
        text: root.detail_value;
        color: AegisPalette.primary_dark;
        font-family: AegisTypography.serif_first;
        font-size: 12px;
        wrap: word-wrap;
    }
}

component RecoveryInspectionCard inherits Rectangle {
    width: 292px;
    height: 176px;
    border-radius: 8px;
    border-width: 1px;
    border-color: AegisPalette.secondary_accent;
    background: AegisPalette.card;

    VerticalLayout {
        padding: 14px;
        spacing: 7px;

        Text {
            text: "Sample Recovery Inspection";
            color: AegisPalette.secondary_accent;
            font-family: AegisTypography.serif_first;
            font-size: 15px;
            font-weight: 800;
        }

        RecoveryDetail {
            detail_label: "Status";
            detail_value: "Inspection available";
        }

        RecoveryDetail {
            detail_label: "Execution";
            detail_value: "sample_exec_001";
        }

        RecoveryDetail {
            detail_label: "Last state";
            detail_value: "Completed";
        }

        RecoveryDetail {
            detail_label: "Terminal";
            detail_value: "Yes";
        }

        RecoveryDetail {
            detail_label: "Recoverability";
            detail_value: "Not recoverable";
        }

        Text {
            text: "Sample only. This card does not read state logs.";
            color: AegisPalette.muted_text;
            font-family: AegisTypography.serif_first;
            font-size: 11px;
            wrap: word-wrap;
        }
    }
}

component RecoveryPlanCard inherits Rectangle {
    width: 292px;
    height: 142px;
    border-radius: 8px;
    border-width: 1px;
    border-color: AegisPalette.attention;
    background: AegisPalette.card;

    VerticalLayout {
        padding: 14px;
        spacing: 7px;

        Text {
            text: "Sample Recovery Plan";
            color: AegisPalette.secondary_accent;
            font-family: AegisTypography.serif_first;
            font-size: 15px;
            font-weight: 800;
        }

        RecoveryDetail {
            detail_label: "Plan status";
            detail_value: "Planned";
        }

        RecoveryDetail {
            detail_label: "Outcome";
            detail_value: "Not recoverable";
        }

        RecoveryDetail {
            detail_label: "Future action";
            detail_value: "No future action";
        }

        Text {
            text: "Sample guidance only. Does not inspect live state. Future evaluation only. Audit retry candidate. Manual review only. Not replay execution.";
            color: AegisPalette.muted_text;
            font-family: AegisTypography.serif_first;
            font-size: 10px;
            wrap: word-wrap;
        }
    }
}

export component AegisWindow inherits Window {
    in-out property <string> evidence_mode_label: "Sample evidence fallback";
    in-out property <string> header_summary: "Fixture-backed operator evidence rendering";
    in-out property <string> policy_bundle_status: "Verified";
    in-out property <string> policy_bundle_summary: "Bundle integrity evidence is present.";
    in-out property <string> policy_decision_status: "Allowed";
    in-out property <string> policy_decision_summary: "Request matches a local policy rule.";
    in-out property <string> authorization_status: "Authorized";
    in-out property <string> authorization_summary: "Wrapper execution authority is bound.";
    in-out property <string> credential_boundary_status: "Satisfied";
    in-out property <string> credential_boundary_summary: "Required class matches authorization.";
    in-out property <string> credential_injection_status: "Handle issued";
    in-out property <string> credential_injection_summary: "Safe local handle reference is present.";
    in-out property <string> wrapper_execution_status: "Executed";
    in-out property <string> wrapper_execution_summary: "Bounded wrapper result is recorded.";
    in-out property <string> audit_status: "Recorded";
    in-out property <string> audit_summary: "Audit evidence is available.";
    in-out property <string> state_status: "Completed";
    in-out property <string> state_summary: "Lifecycle evidence reached completed.";
    in-out property <string> request_status: "Received";
    in-out property <string> request_summary: "Sample request accepted.";
    in-out property <string> validation_status: "Valid";
    in-out property <string> validation_summary: "Request shape matches.";
    in-out property <string> bundle_timeline_status: "Verified";
    in-out property <string> bundle_timeline_summary: "Bundle evidence present.";
    in-out property <string> policy_timeline_status: "Allowed";
    in-out property <string> policy_timeline_summary: "Allow rule matched.";
    in-out property <string> authorization_timeline_status: "Authorized";
    in-out property <string> authorization_timeline_summary: "Wrapper authority bound.";
    in-out property <string> credential_boundary_timeline_status: "Satisfied";
    in-out property <string> credential_boundary_timeline_summary: "Class check passed.";
    in-out property <string> credential_injection_timeline_status: "Handle issued";
    in-out property <string> credential_injection_timeline_summary: "Safe local handle ref.";
    in-out property <string> dispatch_status: "Dispatched";
    in-out property <string> dispatch_summary: "Registered wrapper selected.";
    in-out property <string> wrapper_timeline_status: "Executed";
    in-out property <string> wrapper_timeline_summary: "Bounded result present.";
    in-out property <string> audit_timeline_status: "Recorded";
    in-out property <string> audit_timeline_summary: "Audit evidence exists.";
    in-out property <string> state_timeline_status: "Completed";
    in-out property <string> state_timeline_summary: "Terminal sample state.";
    in-out property <string> error_title: "Sample Normalized Error";
    in-out property <string> error_source: "Static structured_error_report evidence";
    in-out property <string> error_code: "policy_denied";
    in-out property <string> error_severity: "HIGH";
    in-out property <string> error_message: "Request was denied by policy.";
    in-out property <string> error_reason: "The requested action did not match an allowed policy rule.";
    in-out property <string> error_next_action: "Review the policy decision and request context.";
    in-out property <string> error_location: "policy_evaluation";

    title: "AEGIS";
    width: 1280px;
    height: 860px;
    background: AegisPalette.surface;

    HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 220px;
            background: AegisPalette.primary_dark;

            VerticalLayout {
                padding-top: 30px;
                padding-right: 22px;
                padding-bottom: 24px;
                padding-left: 22px;
                spacing: 14px;

                Text {
                    text: "AEGIS";
                    color: AegisPalette.surface;
                    font-family: AegisTypography.serif_first;
                    font-size: 32px;
                    font-weight: 800;
                    horizontal-alignment: center;
                }

                Text {
                    text: "AI Execution Governance & Interception System";
                    color: AegisPalette.surface;
                    font-family: AegisTypography.serif_first;
                    font-size: 13px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Rectangle {
                    height: 1px;
                    background: AegisPalette.secondary_accent;
                }

                NavLabel { label_text: "Overview"; selected: true; }
                NavLabel { label_text: "Executions"; selected: false; }
                NavLabel { label_text: "Audit"; selected: false; }
                NavLabel { label_text: "State"; selected: false; }
                NavLabel { label_text: "Recovery"; selected: false; }
                NavLabel { label_text: "Policy"; selected: false; }
                NavLabel { label_text: "Settings"; selected: false; }

                Rectangle {
                    vertical-stretch: 1;
                    background: AegisPalette.primary_dark;
                }

                Text {
                    text: root.evidence_mode_label;
                    color: AegisPalette.attention;
                    font-family: AegisTypography.serif_first;
                    font-size: 12px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                Text {
                    text: "v0.4.0 pre-alpha local-only";
                    color: AegisPalette.surface;
                    font-family: AegisTypography.serif_first;
                    font-size: 11px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }

        Rectangle {
            background: AegisPalette.surface;

            VerticalLayout {
                padding-top: 28px;
                padding-right: 28px;
                padding-bottom: 24px;
                padding-left: 28px;
                spacing: 14px;

                HorizontalLayout {
                    spacing: 14px;
                    alignment: start;

                    Text {
                        text: "AEGIS";
                        color: AegisPalette.primary_dark;
                        font-family: AegisTypography.serif_first;
                        font-size: 40px;
                        font-weight: 800;
                    }

                    Rectangle {
                        width: 104px;
                        height: 28px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: AegisPalette.attention;
                        background: AegisPalette.attention;

                        Text {
                            text: "PRE-ALPHA";
                            color: AegisPalette.primary_dark;
                            font-family: AegisTypography.serif_first;
                            font-size: 12px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    EvidenceBadge {
                        badge_text: "LOCAL-ONLY";
                        tone: AegisPalette.secondary_accent;
                        badge_width: 110px;
                    }

                    EvidenceBadge {
                        badge_text: "v0.4.0";
                        tone: AegisPalette.primary_dark;
                        text_tone: AegisPalette.surface;
                        badge_width: 86px;
                    }

                    Text {
                        text: root.header_summary;
                        color: AegisPalette.muted_text;
                        font-family: AegisTypography.serif_first;
                        font-size: 17px;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    height: 56px;
                    border-radius: 8px;
                    border-width: 1px;
                    border-color: AegisPalette.border;
                    background: AegisPalette.panel;

                    HorizontalLayout {
                        padding: 12px;
                        spacing: 12px;

                        Text {
                            width: 118px;
                            text: "Evidence source";
                            color: AegisPalette.primary_dark;
                            font-family: AegisTypography.serif_first;
                            font-size: 14px;
                            font-weight: 800;
                            vertical-alignment: center;
                        }

                        EvidenceBadge {
                            badge_text: root.evidence_mode_label;
                            tone: AegisPalette.primary_dark;
                            text_tone: AegisPalette.surface;
                            badge_width: 238px;
                        }

                        EvidenceBadge {
                            badge_text: "Sample evidence remains labeled";
                            tone: AegisPalette.attention;
                            badge_width: 230px;
                        }

                        Text {
                            text: "Local-only developer-oriented pre-alpha. Not production-ready.";
                            color: AegisPalette.muted_text;
                            font-family: AegisTypography.serif_first;
                            font-size: 13px;
                            vertical-alignment: center;
                            wrap: word-wrap;
                        }
                    }
                }

                HorizontalLayout {
                    spacing: 16px;

                    VerticalLayout {
                        spacing: 12px;

                        SectionTitle { title_text: "Current Execution Status"; }

                        HorizontalLayout {
                            spacing: 10px;
                            StatusCard { card_title: "Policy Bundle"; card_status: root.policy_bundle_status; summary: root.policy_bundle_summary; evidence_source: "policy_bundle"; accent: AegisPalette.primary_dark; }
                            StatusCard { card_title: "Policy Decision"; card_status: root.policy_decision_status; summary: root.policy_decision_summary; evidence_source: "policy_evaluation"; accent: AegisPalette.primary_dark; }
                            StatusCard { card_title: "Authorization"; card_status: root.authorization_status; summary: root.authorization_summary; evidence_source: "execution_authorization"; accent: AegisPalette.primary_dark; }
                            StatusCard { card_title: "Credential Boundary"; card_status: root.credential_boundary_status; summary: root.credential_boundary_summary; evidence_source: "credential_boundary"; accent: AegisPalette.primary_dark; }
                            StatusCard { card_title: "Credential Injection"; card_status: root.credential_injection_status; summary: root.credential_injection_summary; evidence_source: "credential_injection"; accent: AegisPalette.secondary_accent; }
                        }

                        HorizontalLayout {
                            spacing: 10px;
                            StatusCard { card_title: "Wrapper Execution"; card_status: root.wrapper_execution_status; summary: root.wrapper_execution_summary; evidence_source: "wrapper_execution"; accent: AegisPalette.primary_dark; }
                            StatusCard { card_title: "Audit Log"; card_status: root.audit_status; summary: root.audit_summary; evidence_source: "audit_record"; accent: AegisPalette.primary_dark; }
                            StatusCard { card_title: "State Log"; card_status: root.state_status; summary: root.state_summary; evidence_source: "execution_lifecycle"; accent: AegisPalette.primary_dark; }
                            StatusCard { card_title: "Recovery Inspection"; card_status: "Sample only"; summary: "Live health.check does not inspect state logs."; evidence_source: "sample recovery_inspection_report"; accent: AegisPalette.secondary_accent; }
                            StatusCard { card_title: "Recovery Plan"; card_status: "Sample only"; summary: "Live health.check does not plan recovery."; evidence_source: "sample recovery_plan_report"; accent: AegisPalette.attention; }
                        }

                        Rectangle {
                            height: 252px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: AegisPalette.border;
                            background: AegisPalette.card;

                            VerticalLayout {
                                padding: 16px;
                                spacing: 10px;

                                SectionTitle { title_text: "Execution Timeline"; }

                                Text {
                                    text: "Display labels derive from live health.check backend evidence when available; recovery stages remain sample-only.";
                                    color: AegisPalette.muted_text;
                                    font-family: AegisTypography.serif_first;
                                    font-size: 12px;
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    TimelineStep { stage_label: "Request"; stage_status: root.request_status; summary: root.request_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Validation"; stage_status: root.validation_status; summary: root.validation_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Policy Bundle"; stage_status: root.bundle_timeline_status; summary: root.bundle_timeline_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Policy Decision"; stage_status: root.policy_timeline_status; summary: root.policy_timeline_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Authorization"; stage_status: root.authorization_timeline_status; summary: root.authorization_timeline_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Credential Boundary"; stage_status: root.credential_boundary_timeline_status; summary: root.credential_boundary_timeline_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Credential Injection"; stage_status: root.credential_injection_timeline_status; summary: root.credential_injection_timeline_summary; accent: AegisPalette.secondary_accent; }
                                }

                                HorizontalLayout {
                                    spacing: 10px;
                                    TimelineStep { stage_label: "Wrapper Dispatch"; stage_status: root.dispatch_status; summary: root.dispatch_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Wrapper Execution"; stage_status: root.wrapper_timeline_status; summary: root.wrapper_timeline_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Audit"; stage_status: root.audit_timeline_status; summary: root.audit_timeline_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "State"; stage_status: root.state_timeline_status; summary: root.state_timeline_summary; accent: AegisPalette.primary_dark; }
                                    TimelineStep { stage_label: "Recovery Inspection"; stage_status: "Sample only"; summary: "No live state inspection."; accent: AegisPalette.secondary_accent; }
                                    TimelineStep { stage_label: "Recovery Plan"; stage_status: "Sample only"; summary: "No live recovery plan."; accent: AegisPalette.attention; }
                                }
                            }
                        }

                        Rectangle {
                            height: 84px;
                            border-radius: 8px;
                            border-width: 1px;
                            border-color: AegisPalette.primary_dark;
                            background: AegisPalette.panel;

                            HorizontalLayout {
                                padding: 16px;
                                spacing: 14px;

                                Text {
                                    width: 124px;
                                    text: "Backend evidence drives this UI";
                                    color: AegisPalette.primary_dark;
                                    font-family: AegisTypography.serif_first;
                                    font-size: 14px;
                                    font-weight: 800;
                                    wrap: word-wrap;
                                }

                                Text {
                                    text: "The UI is an operator surface, not an authority boundary. Fixed read-only live health.check evidence. Labeled sample recovery evidence. No arbitrary requests, credentials, mutation dispatch, replay, or recovery.";
                                    color: AegisPalette.muted_text;
                                    font-family: AegisTypography.serif_first;
                                    font-size: 13px;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: 12px;

                        ErrorCard {
                            error_title: root.error_title;
                            error_source: root.error_source;
                            error_code: root.error_code;
                            error_severity: root.error_severity;
                            error_message: root.error_message;
                            error_reason: root.error_reason;
                            error_next_action: root.error_next_action;
                            error_location: root.error_location;
                        }
                        RecoveryInspectionCard {}
                        RecoveryPlanCard {}
                    }
                }
            }
        }
    }
}
